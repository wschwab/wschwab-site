---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const work = (await getCollection('work', (e) => !e.data.draft))
  .sort((a, b) => (a.data.featured ?? 99) - (b.data.featured ?? 99));
---
<Base title="Work" description="Selected work by William Schwab — smart contracts, engineering leadership, and Ethereum ecosystem projects.">
  <main>
    <div class="page">
      <div class="page-head">
        <a class="backlink" href="/#work">← back home</a>
        <h1>All <em>work.</em></h1>
        <hr>
      </div>
      <div class="cards">
        {work.map((item) => (
          <a class="card" href={item.data.external ?? `/work/${item.id}/`}>
            <div class="tags">
              {item.data.tags.map((t) => <span>{t}</span>)}
              {item.data.soft_tags.map((t) => <span class="warn">{t}</span>)}
            </div>
            <h3>{item.data.title}</h3>
            <p>{item.data.summary}</p>
            <div class="go">{item.data.cta}</div>
          </a>
        ))}
      </div>
    </div>
  </main>
</Base>
