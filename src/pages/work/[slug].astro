---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const work = await getCollection('work', (e) => !e.data.draft);
  return work.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<Base title={entry.data.title} description={entry.data.summary}>
  <main>
    <div class="page">
      <div class="page-head">
        <a class="backlink" href="/#work">← back home</a>
        <h1>{entry.data.title}</h1>
        <div class="meta">{entry.data.role} &nbsp;·&nbsp; {entry.data.period}</div>
        <div class="tags">
          {entry.data.tags.map((t) => <span>{t}</span>)}
          {entry.data.soft_tags.map((t) => <span class="warn">{t}</span>)}
        </div>
        <hr>
      </div>
      <div class="prose">
        <Content />
        {entry.data.links.length > 0 && (
          <ul>
            {entry.data.links.map((l) => <li><a href={l.url}>{l.label}</a></li>)}
          </ul>
        )}
      </div>
    </div>
  </main>
</Base>
