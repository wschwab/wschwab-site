#!/usr/bin/env bash
# commit "<message>" — describe with jj, push to GitHub + Radicle, pin to IPFS/IPNS.
# Cloudflare deploys via GitHub Actions on push; this script handles the mirrors.
set -uo pipefail
cd "$(dirname "$0")"

msg="${1:?usage: ./commit \"message\"}"
fail=0
step() { printf '\n\033[33m── %s\033[0m\n' "$1"; }

step "jj: commit + advance main"
if [ -n "$(jj diff --name-only)" ]; then
  jj commit -m "$msg" || exit 1
  jj bookmark set main -r @- || { echo "bookmark set failed"; exit 1; }
else
  echo "nothing to commit (working copy clean); continuing with push + pin"
fi

step "push: GitHub (origin) — triggers Cloudflare deploy"
jj git push --bookmark main || fail=1

step "push: Radicle"
if rad inspect >/dev/null 2>&1; then
  git push rad main && rad sync || { echo "rad push/sync failed (node running? key unsealed?)"; fail=1; }
else
  echo "repo not initialized on Radicle — run: rad init (once)"; fail=1
fi

step "build"
npm run build >/dev/null || { echo "build failed — skipping IPFS pin"; exit 1; }

step "pin: IPFS + publish IPNS"
if ipfs swarm peers >/dev/null 2>&1; then
  if ! ipfs key list | grep -qx wschwab-site; then
    ipfs key gen wschwab-site >/dev/null
    echo "created IPNS key 'wschwab-site'"
  fi
  cid=$(ipfs add -rQ --cid-version 1 dist) || { echo "ipfs add failed"; exit 1; }
  echo "CID: $cid"
  echo "     https://dweb.link/ipfs/$cid"
  ipfs name publish --key=wschwab-site --quieter "/ipfs/$cid" || fail=1
  ipns=$(ipfs key list -l | awk '$2=="wschwab-site"{print $1}')
  echo "IPNS: $ipns"
  echo "     https://dweb.link/ipns/$ipns"
else
  echo "kubo daemon not running — skipped IPFS pin (start with: ipfs daemon)"
  fail=1
fi

step "on-chain pointer (WNS/GNS)"
# gwei.domains/wei.domains gateways only resolve raw IPFS contenthash (not IPNS),
# so each new CID needs a signed setContenthash. Emit ready-to-sign calldata.
if [ -n "${cid:-}" ]; then
  hex=$(ipfs cid format -b base16 "$cid"); hex=${hex#f}
  ch="e301${hex}"
  chlen=$(printf '%064x' $((${#ch} / 2)))
  pad=$(python3 -c "print('00'*((32-${#ch}//2%32)%32))")
  WNS_ID=ffd9adc3e2f54454dd438f3fb01dfd095b8828510322d94f2d4fd13a50a8f4b1
  GNS_ID=ce9fee42672fc9e9a17521f8098347751c225591c1e530bfe16bd6a3f476bbea
  off=$(printf '%064x' 64)
  echo "if publishing on-chain, send from the name-owner wallet:"
  echo "  WNS 0x0000000000696760E15f265e828DB644A0c242EB:"
  echo "  0x88f97a67${WNS_ID}${off}${chlen}${ch}${pad}"
  echo "  GNS 0x9D51D507bC7264d4fe8AD1cF7fe191933a0A81D6:"
  echo "  0x88f97a67${GNS_ID}${off}${chlen}${ch}${pad}"
fi

# step "pin: Swarm"  — deferred; requires a funded bee node (postage stamps)

step "done"
[ "$fail" -eq 0 ] && echo "all targets updated ✓" || echo "finished with warnings ⚠ (see above)"
exit "$fail"
